            "text": "许大对近期白银的暴跌咋看，是否与多逼空后交易所下场干预相关？",
            "expired": false,
            "anonymous": false,
            "owner_detail": {
              "questions_count": 4,
              "join_time": "2024-03-14T12:43:15.137+0800",
              "status": "joined"
            },
